{
  "extends": "./tsconfig.test.base.json",
  "compilerOptions": {
    "types": ["node", "vitest", "vitest/globals", "vitest/importMeta", "./env.d.ts"],
    "paths": {
      "@varavel/vdl-plugin-sdk": ["./src/core/index.ts"],
      "@varavel/vdl-plugin-sdk/testing": ["./src/testing/index.ts"],
      "@varavel/vdl-plugin-sdk/utils/*": ["./src/utils/*/index.ts"]
    }
  },
  "include": [
    "vitest.config.ts",
    "src/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "tests/**/*.ts",
    "e2e/**/*.ts"
  ]
}
