{
  "entryPoints": [
    "./src/entrypoints/core.ts",
    "./src/entrypoints/utils.ts",
    "./src/entrypoints/testing.ts"
  ],
  "entryPointStrategy": "resolve",
  "readme": "none",
  "router": "module",
  "entryFileName": "index",
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "hideBreadcrumbs": true,
  "hidePageHeader": true,
  "disableSources": true,
  "useCodeBlocks": true,
  "cleanOutputDir": true,
  "plugin": ["typedoc-plugin-markdown"],
  "out": "./docs/api"
}
