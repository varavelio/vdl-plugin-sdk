{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2016"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["@varavel/vdl-plugin-sdk"]
  }
}
