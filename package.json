{
  "name": "@varavel/vdl-plugin-sdk",
  "version": "0.0.0",
  "description": "SDK to build plugins for VDL using TypeScript",
  "keywords": [
    "varavel",
    "vdl",
    "vdl-plugin",
    "vdl-plugin-sdk",
    "vdl-sdk",
    "sdk"
  ],
  "homepage": "https://github.com/varavelio/vdl-plugin-sdk#readme",
  "bugs": {
    "url": "https://github.com/varavelio/vdl-plugin-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varavelio/vdl-plugin-sdk.git"
  },
  "license": "MIT",
  "author": "Varavel",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/core/index.cjs",
  "module": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "bin": {
    "vdl-plugin": "./bin/vdl-plugin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs",
      "default": "./dist/core/index.js"
    },
    "./utils/*": {
      "types": "./dist/utils/*/index.d.ts",
      "import": "./dist/utils/*/index.js",
      "require": "./dist/utils/*/index.cjs",
      "default": "./dist/utils/*/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.cjs",
      "default": "./dist/testing/index.js"
    },
    "./tsconfig.app.base.json": "./tsconfig.app.base.json",
    "./tsconfig.test.base.json": "./tsconfig.test.base.json"
  },
  "files": [
    "bin",
    "schemas",
    "src",
    "dist",
    "tsconfig.app.base.json",
    "tsconfig.test.base.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:docs && npm run build:bundle",
    "build:bundle": "tsdown",
    "build:docs": "node ./scripts/generate-docs/index.ts",
    "format": "npm run format:dprint && npm run format:biome",
    "format:dprint": "dprint fmt --config ./dprint.json --log-level warn",
    "format:biome": "biome format --write --config-path ./biome.json --log-level warn --no-errors-on-unmatched .",
    "lint": "tsc --noEmit && npm run lint:dprint && npm run lint:biome",
    "lint:dprint": "dprint check --config ./dprint.json --log-level warn",
    "lint:biome": "biome check --config-path ./biome.json --log-level warn --no-errors-on-unmatched .",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "node ./e2e/goja/run.ts",
    "ci": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "esbuild": "0.27.3",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/node": "25.5.0",
    "@varavel/vdl": "0.5.0-alpha.5",
    "dedent": "1.7.2",
    "dprint": "0.52.0",
    "es-toolkit": "1.45.1",
    "ohash": "2.0.11",
    "pathe": "2.0.3",
    "pluralize": "8.0.0",
    "smol-toml": "1.6.1",
    "tsdown": "0.21.0",
    "typedoc": "0.28.18",
    "typedoc-plugin-markdown": "4.11.0",
    "vitest": "4.0.18",
    "yaml": "2.8.3"
  }
}
