{
  "name": "@varavel/vdl-plugin-sdk",
  "version": "0.0.0",
  "description": "SDK to build plugins for VDL using TypeScript",
  "keywords": [
    "varavel",
    "vdl",
    "vdl-plugin",
    "sdk"
  ],
  "homepage": "https://github.com/varavelio/vdl-plugin-sdk#readme",
  "bugs": {
    "url": "https://github.com/varavelio/vdl-plugin-sdk/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/varavelio/vdl-plugin-sdk.git"
  },
  "license": "MIT",
  "author": "Varavel LLC",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "schemas",
    "src",
    "dist",
    "tsconfig.base.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "ci": "npm run lint && npm run test && npm run build",
    "build": "tsdown",
    "format": "biome format",
    "lint": "tsc --noEmit && biome check",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@varavel/vdl": "0.4.0-alpha.5",
    "tsdown": "0.21.0",
    "vitest": "4.0.18"
  },
  "dependencies": {
    "esbuild": "0.27.3",
    "typescript": "5.9.3"
  }
}
